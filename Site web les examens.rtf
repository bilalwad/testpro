\pard\sa200\sl276\slmult1\f0\fs22\lang12 <!DOCTYPE html>\par
<html lang="fr">\par
<head>\par
<meta charset="UTF-8">\par
<meta name="viewport" content="width=device-width, initial-scale=1.0">\par
<title>TestPro \f1\emdash  Certifications en Ligne</title>\par
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">\par
<style>\par
  :root \{\par
    --navy: #0a1628;\par
    --navy-mid: #132040;\par
    --gold: #c9a84c;\par
    --gold-light: #e8c97a;\par
    --cream: #f8f4ec;\par
    --white: #ffffff;\par
    --text: #1a2035;\par
    --muted: #7a8099;\par
    --success: #1a8f5c;\par
    --border: #e2ddd4;\par
    --shadow: 0 4px 32px rgba(10,22,40,0.10);\par
  \}\par
  * \{ box-sizing: border-box; margin: 0; padding: 0; \}\par
  body \{ font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); min-height: 100vh; \}\par
\par
  /* ===== SCREENS ===== */\par
  .screen \{ display: none; min-height: 100vh; \}\par
  .screen.active \{ display: flex; flex-direction: column; \}\par
\par
  /* ===== NAV ===== */\par
  nav \{\par
    background: var(--navy);\par
    padding: 0 2.5rem;\par
    height: 64px;\par
    display: flex;\par
    align-items: center;\par
    justify-content: space-between;\par
    position: sticky; top: 0; z-index: 100;\par
  \}\par
  .logo \{ font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1.4rem; letter-spacing: 1px; \}\par
  .logo span \{ color: var(--white); \}\par
  .nav-links \{ display: flex; gap: 2rem; \}\par
  .nav-links a \{ color: rgba(255,255,255,0.65); font-size: 0.88rem; font-weight: 500; cursor: pointer; text-decoration: none; transition: color .2s; \}\par
  .nav-links a:hover \{ color: var(--gold); \}\par
\par
  /* ===== HERO ===== */\par
  .hero \{\par
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1a2f5a 100%);\par
    padding: 5rem 2.5rem 4rem;\par
    display: flex;\par
    align-items: center;\par
    justify-content: center;\par
    text-align: center;\par
    position: relative;\par
    overflow: hidden;\par
  \}\par
  .hero::before \{\par
    content: '';\par
    position: absolute;\par
    inset: 0;\par
    background: radial-gradient(ellipse at 70% 30%, rgba(201,168,76,0.12) 0%, transparent 60%);\par
    pointer-events: none;\par
  \}\par
  .hero-inner \{ max-width: 680px; position: relative; \}\par
  .hero-badge \{\par
    display: inline-flex; align-items: center; gap: 6px;\par
    background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.4);\par
    color: var(--gold-light); font-size: 0.78rem; font-weight: 600;\par
    letter-spacing: 1.5px; text-transform: uppercase;\par
    padding: 5px 14px; border-radius: 100px; margin-bottom: 1.5rem;\par
  \}\par
  .hero h1 \{\par
    font-family: 'Playfair Display', serif;\par
    color: var(--white);\par
    font-size: clamp(2.2rem, 5vw, 3.4rem);\par
    line-height: 1.18;\par
    margin-bottom: 1.2rem;\par
  \}\par
  .hero h1 em \{ color: var(--gold); font-style: normal; \}\par
  .hero p \{ color: rgba(255,255,255,0.65); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2.4rem; \}\par
  .btn-primary \{\par
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);\par
    color: var(--navy);\par
    font-weight: 700; font-size: 0.9rem; letter-spacing: 0.5px;\par
    padding: 13px 34px; border-radius: 6px;\par
    border: none; cursor: pointer;\par
    box-shadow: 0 4px 20px rgba(201,168,76,0.35);\par
    transition: transform .2s, box-shadow .2s;\par
  \}\par
  .btn-primary:hover \{ transform: translateY(-2px); box-shadow: 0 6px 28px rgba(201,168,76,0.45); \}\par
  .btn-secondary \{\par
    background: transparent;\par
    color: var(--white);\par
    border: 1.5px solid rgba(255,255,255,0.35);\par
    font-weight: 500; font-size: 0.9rem;\par
    padding: 12px 28px; border-radius: 6px;\par
    cursor: pointer; margin-left: 12px;\par
    transition: border-color .2s, background .2s;\par
  \}\par
  .btn-secondary:hover \{ border-color: var(--gold); background: rgba(201,168,76,0.08); \}\par
\par
  /* ===== STATS BAR ===== */\par
  .stats-bar \{\par
    background: var(--white);\par
    border-bottom: 1px solid var(--border);\par
    display: flex; justify-content: center; gap: 4rem;\par
    padding: 1.4rem 2rem;\par
    flex-wrap: wrap;\par
  \}\par
  .stat \{ text-align: center; \}\par
  .stat-num \{ font-family: 'Playfair Display', serif; font-size: 1.7rem; color: var(--navy); font-weight: 700; \}\par
  .stat-label \{ font-size: 0.78rem; color: var(--muted); font-weight: 500; margin-top: 2px; \}\par
\par
  /* ===== CATALOG ===== */\par
  .catalog \{ padding: 3.5rem 2.5rem; max-width: 1100px; margin: 0 auto; width: 100%; \}\par
  .section-title \{\par
    font-family: 'Playfair Display', serif;\par
    font-size: 1.7rem; color: var(--navy);\par
    margin-bottom: 0.5rem;\par
  \}\par
  .section-sub \{ color: var(--muted); font-size: 0.9rem; margin-bottom: 2rem; \}\par
  .test-grid \{ display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1.4rem; \}\par
  .test-card \{\par
    background: var(--white);\par
    border: 1px solid var(--border);\par
    border-radius: 12px;\par
    padding: 1.6rem;\par
    cursor: pointer;\par
    transition: box-shadow .25s, transform .25s, border-color .25s;\par
    position: relative;\par
    overflow: hidden;\par
  \}\par
  .test-card::before \{\par
    content: '';\par
    position: absolute; top: 0; left: 0; right: 0; height: 4px;\par
    background: linear-gradient(90deg, var(--gold), var(--gold-light));\par
    transform: scaleX(0); transform-origin: left;\par
    transition: transform .3s;\par
  \}\par
  .test-card:hover \{ box-shadow: var(--shadow); transform: translateY(-3px); border-color: rgba(201,168,76,0.4); \}\par
  .test-card:hover::before \{ transform: scaleX(1); \}\par
  .card-icon \{ font-size: 2rem; margin-bottom: 0.8rem; \}\par
  .card-category \{ font-size: 0.72rem; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; \}\par
  .card-title \{ font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--navy); margin-bottom: 0.5rem; \}\par
  .card-desc \{ font-size: 0.84rem; color: var(--muted); line-height: 1.55; margin-bottom: 1.2rem; \}\par
  .card-meta \{ display: flex; gap: 1rem; font-size: 0.78rem; color: var(--muted); align-items: center; \}\par
  .card-meta span \{ display: flex; align-items: center; gap: 4px; \}\par
  .card-price \{\par
    position: absolute; top: 1.2rem; right: 1.2rem;\par
    background: var(--navy); color: var(--gold);\par
    font-weight: 700; font-size: 0.85rem;\par
    padding: 3px 10px; border-radius: 100px;\par
  \}\par
  .badge-free \{ background: #e8f5ee; color: var(--success); \}\par
\par
  /* ===== TEST SCREEN ===== */\par
  .test-layout \{ display: flex; gap: 0; flex: 1; \}\par
  .test-sidebar \{\par
    width: 300px; min-height: 100%;\par
    background: var(--navy);\par
    padding: 2rem 1.6rem;\par
    flex-shrink: 0;\par
  \}\par
  .test-main \{ flex: 1; padding: 2.5rem; overflow-y: auto; \}\par
  .test-header \{ margin-bottom: 2rem; \}\par
  .test-title \{ font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--navy); margin-bottom: 0.3rem; \}\par
  .test-sub \{ color: var(--muted); font-size: 0.88rem; \}\par
  .progress-wrap \{ margin-bottom: 1.4rem; \}\par
  .progress-label \{ display: flex; justify-content: space-between; font-size: 0.8rem; color: rgba(255,255,255,0.6); margin-bottom: 6px; \}\par
  .progress-bar \{ height: 6px; background: rgba(255,255,255,0.12); border-radius: 100px; overflow: hidden; \}\par
  .progress-fill \{ height: 100%; background: linear-gradient(90deg, var(--gold), var(--gold-light)); border-radius: 100px; transition: width .4s; \}\par
  .q-dots \{ display: flex; flex-wrap: wrap; gap: 6px; margin-top: 1.5rem; \}\par
  .q-dot \{\par
    width: 28px; height: 28px;\par
    border-radius: 6px; font-size: 0.72rem; font-weight: 600;\par
    display: flex; align-items: center; justify-content: center;\par
    cursor: pointer; transition: background .2s;\par
    background: rgba(255,255,255,0.08);\par
    color: rgba(255,255,255,0.55);\par
  \}\par
  .q-dot.answered \{ background: rgba(201,168,76,0.25); color: var(--gold); \}\par
  .q-dot.current \{ background: var(--gold); color: var(--navy); \}\par
  .timer-wrap \{\par
    margin-top: 2rem;\par
    background: rgba(255,255,255,0.06);\par
    border-radius: 10px; padding: 1.2rem;\par
    text-align: center;\par
  \}\par
  .timer-label \{ font-size: 0.75rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; \}\par
  .timer-val \{ font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--white); \}\par
  .timer-val.warning \{ color: #ff6b6b; \}\par
\par
  /* Question */\par
  .question-card \{\par
    background: var(--white);\par
    border: 1px solid var(--border);\par
    border-radius: 14px;\par
    padding: 2.2rem;\par
    margin-bottom: 1.4rem;\par
    box-shadow: var(--shadow);\par
  \}\par
  .q-num \{ font-size: 0.78rem; font-weight: 600; color: var(--gold); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.6rem; \}\par
  .q-text \{ font-size: 1.05rem; color: var(--navy); line-height: 1.65; margin-bottom: 1.8rem; font-weight: 500; \}\par
  .options \{ display: flex; flex-direction: column; gap: 0.7rem; \}\par
  .option \{\par
    display: flex; align-items: center; gap: 12px;\par
    padding: 13px 16px;\par
    border: 1.5px solid var(--border);\par
    border-radius: 8px; cursor: pointer;\par
    transition: border-color .2s, background .2s;\par
    font-size: 0.9rem; color: var(--text);\par
  \}\par
  .option:hover \{ border-color: var(--gold); background: rgba(201,168,76,0.05); \}\par
  .option.selected \{ border-color: var(--gold); background: rgba(201,168,76,0.1); color: var(--navy); font-weight: 500; \}\par
  .option-letter \{\par
    width: 28px; height: 28px; border-radius: 6px;\par
    display: flex; align-items: center; justify-content: center;\par
    font-size: 0.78rem; font-weight: 700;\par
    background: var(--border); color: var(--muted);\par
    flex-shrink: 0; transition: background .2s, color .2s;\par
  \}\par
  .option.selected .option-letter \{ background: var(--gold); color: var(--navy); \}\par
  .nav-btns \{ display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; \}\par
  .btn-nav \{\par
    background: var(--white); border: 1.5px solid var(--border);\par
    color: var(--text); padding: 10px 22px; border-radius: 6px;\par
    font-weight: 500; font-size: 0.88rem; cursor: pointer;\par
    transition: border-color .2s, background .2s;\par
  \}\par
  .btn-nav:hover \{ border-color: var(--navy); background: var(--cream); \}\par
  .btn-submit \{\par
    background: linear-gradient(135deg, var(--navy), #1a2f5a);\par
    color: var(--white); border: none;\par
    padding: 11px 28px; border-radius: 6px;\par
    font-weight: 600; font-size: 0.9rem; cursor: pointer;\par
    transition: opacity .2s;\par
  \}\par
  .btn-submit:hover \{ opacity: 0.9; \}\par
\par
  /* ===== RESULTS ===== */\par
  .results-wrap \{ max-width: 780px; margin: 0 auto; padding: 3rem 2rem; \}\par
  .score-card \{\par
    background: var(--navy);\par
    border-radius: 16px;\par
    padding: 2.5rem;\par
    text-align: center;\par
    color: var(--white);\par
    margin-bottom: 1.8rem;\par
    position: relative; overflow: hidden;\par
  \}\par
  .score-card::before \{\par
    content: '';\par
    position: absolute; inset: 0;\par
    background: radial-gradient(circle at 50% 0%, rgba(201,168,76,0.2), transparent 60%);\par
    pointer-events: none;\par
  \}\par
  .score-pct \{\par
    font-family: 'Playfair Display', serif;\par
    font-size: 4.5rem; color: var(--gold);\par
    line-height: 1; margin-bottom: 0.3rem;\par
  \}\par
  .score-pct span \{ font-size: 2rem; \}\par
  .score-status \{ font-size: 1.2rem; font-weight: 600; margin-bottom: 0.4rem; \}\par
  .score-msg \{ font-size: 0.88rem; color: rgba(255,255,255,0.6); \}\par
  .result-stats \{\par
    display: flex; justify-content: center; gap: 3rem;\par
    margin-top: 1.8rem; flex-wrap: wrap;\par
  \}\par
  .r-stat \{ text-align: center; \}\par
  .r-stat-num \{ font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--white); \}\par
  .r-stat-label \{ font-size: 0.75rem; color: rgba(255,255,255,0.5); \}\par
\par
  .cert-promo \{\par
    background: var(--white);\par
    border: 1px solid var(--border);\par
    border-radius: 14px;\par
    padding: 2rem;\par
    display: flex; align-items: center; gap: 2rem;\par
    margin-bottom: 1.4rem;\par
    box-shadow: var(--shadow);\par
  \}\par
  .cert-icon \{ font-size: 3.5rem; flex-shrink: 0; \}\par
  .cert-text h3 \{ font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--navy); margin-bottom: 0.4rem; \}\par
  .cert-text p \{ font-size: 0.86rem; color: var(--muted); line-height: 1.55; \}\par
  .cert-actions \{ display: flex; gap: 0.8rem; margin-top: 1rem; \}\par
  .btn-cert \{\par
    background: linear-gradient(135deg, var(--gold), var(--gold-light));\par
    color: var(--navy); font-weight: 700; font-size: 0.88rem;\par
    padding: 10px 22px; border-radius: 6px; border: none; cursor: pointer;\par
    transition: transform .2s;\par
  \}\par
  .btn-cert:hover \{ transform: translateY(-1px); \}\par
  .btn-outline \{\par
    background: transparent; border: 1.5px solid var(--border);\par
    color: var(--text); font-size: 0.88rem; font-weight: 500;\par
    padding: 10px 20px; border-radius: 6px; cursor: pointer;\par
    transition: border-color .2s;\par
  \}\par
  .btn-outline:hover \{ border-color: var(--navy); \}\par
\par
  /* Answers review */\par
  .answers-review \{ background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 1.8rem; \}\par
  .review-title \{ font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--navy); margin-bottom: 1.2rem; \}\par
  .review-item \{ padding: 0.9rem 0; border-bottom: 1px solid var(--border); display: flex; gap: 12px; align-items: flex-start; \}\par
  .review-item:last-child \{ border-bottom: none; \}\par
  .review-icon \{ font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; \}\par
  .review-q \{ font-size: 0.88rem; color: var(--text); line-height: 1.5; \}\par
  .review-ans \{ font-size: 0.8rem; margin-top: 4px; color: var(--muted); \}\par
  .correct-ans \{ color: var(--success); font-weight: 600; \}\par
  .wrong-ans \{ color: #e05252; \}\par
\par
  /* ===== CERTIFICATE ===== */\par
  .cert-screen \{ background: #f0ece3; \}\par
  .cert-wrap \{ max-width: 820px; margin: 2.5rem auto; padding: 0 1.5rem; \}\par
  .cert-doc \{\par
    background: var(--white);\par
    border: 1px solid #d4cfc5;\par
    border-radius: 4px;\par
    padding: 4rem;\par
    text-align: center;\par
    position: relative;\par
    box-shadow: 0 8px 48px rgba(0,0,0,0.12);\par
  \}\par
  .cert-doc::before, .cert-doc::after \{\par
    content: '';\par
    position: absolute;\par
    top: 16px; left: 16px; right: 16px; bottom: 16px;\par
    border: 1.5px solid var(--gold);\par
    border-radius: 2px;\par
    pointer-events: none;\par
  \}\par
  .cert-doc::after \{\par
    top: 22px; left: 22px; right: 22px; bottom: 22px;\par
    border-color: rgba(201,168,76,0.35);\par
  \}\par
  .cert-logo \{ font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--navy); letter-spacing: 2px; margin-bottom: 0.4rem; \}\par
  .cert-logo-sub \{ font-size: 0.72rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; \}\par
  .cert-divider \{\par
    width: 80px; height: 2px;\par
    background: linear-gradient(90deg, transparent, var(--gold), transparent);\par
    margin: 1.2rem auto;\par
  \}\par
  .cert-headline \{ font-family: 'Playfair Display', serif; font-size: 0.8rem; color: var(--muted); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 0.6rem; \}\par
  .cert-name \{ font-family: 'Playfair Display', serif; font-size: 2.6rem; color: var(--navy); font-style: italic; margin-bottom: 0.4rem; \}\par
  .cert-body \{ font-size: 0.92rem; color: var(--muted); line-height: 1.7; margin-bottom: 0.5rem; \}\par
  .cert-test \{ font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--navy); margin: 0.6rem 0; \}\par
  .cert-score-badge \{\par
    display: inline-flex; align-items: center; justify-content: center;\par
    width: 80px; height: 80px; border-radius: 50%;\par
    border: 2px solid var(--gold);\par
    font-family: 'Playfair Display', serif;\par
    font-size: 1.5rem; color: var(--navy);\par
    margin: 1rem auto;\par
  \}\par
  .cert-footer \{ display: flex; justify-content: space-between; align-items: flex-end; margin-top: 2.5rem; \}\par
  .cert-sig \{ text-align: left; \}\par
  .cert-sig-name \{ font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--navy); font-style: italic; \}\par
  .cert-sig-title \{ font-size: 0.72rem; color: var(--muted); border-top: 1px solid var(--border); padding-top: 6px; margin-top: 4px; \}\par
  .cert-id \{ text-align: right; font-size: 0.7rem; color: var(--muted); \}\par
  .cert-actions-bar \{\par
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;\par
    margin-top: 2rem; margin-bottom: 3rem;\par
  \}\par
\par
  /* ===== PAYMENT ===== */\par
  .payment-wrap \{ max-width: 560px; margin: 3rem auto; padding: 0 1.5rem; \}\par
  .payment-card \{\par
    background: var(--white);\par
    border: 1px solid var(--border);\par
    border-radius: 16px;\par
    overflow: hidden;\par
    box-shadow: var(--shadow);\par
  \}\par
  .payment-header \{\par
    background: var(--navy);\par
    padding: 1.8rem 2rem;\par
    display: flex; align-items: center; gap: 1rem;\par
  \}\par
  .payment-header-text h3 \{ color: var(--white); font-family: 'Playfair Display', serif; font-size: 1.2rem; \}\par
  .payment-header-text p \{ color: rgba(255,255,255,0.6); font-size: 0.83rem; margin-top: 2px; \}\par
  .price-badge \{\par
    margin-left: auto;\par
    background: rgba(201,168,76,0.2);\par
    color: var(--gold-light);\par
    font-family: 'Playfair Display', serif;\par
    font-size: 1.4rem;\par
    padding: 6px 16px; border-radius: 8px;\par
  \}\par
  .payment-body \{ padding: 2rem; \}\par
  .form-row \{ display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; \}\par
  .form-group \{ margin-bottom: 1.2rem; \}\par
  .form-label \{ display: block; font-size: 0.8rem; font-weight: 600; color: var(--text); margin-bottom: 5px; \}\par
  .form-input \{\par
    width: 100%; padding: 10px 14px;\par
    border: 1.5px solid var(--border);\par
    border-radius: 7px; font-family: 'DM Sans', sans-serif;\par
    font-size: 0.9rem; color: var(--text);\par
    background: var(--cream);\par
    transition: border-color .2s, box-shadow .2s;\par
    outline: none;\par
  \}\par
  .form-input:focus \{ border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,168,76,0.12); \}\par
  .card-icons \{ display: flex; gap: 6px; margin-bottom: 1rem; \}\par
  .card-icon-badge \{\par
    background: var(--cream); border: 1px solid var(--border);\par
    border-radius: 4px; padding: 3px 8px;\par
    font-size: 0.7rem; font-weight: 700; color: var(--muted);\par
  \}\par
  .secure-badge \{\par
    display: flex; align-items: center; gap: 8px;\par
    background: #e8f5ee; border-radius: 6px; padding: 8px 12px;\par
    font-size: 0.78rem; color: var(--success); margin-bottom: 1.4rem;\par
  \}\par
  .summary-line \{ display: flex; justify-content: space-between; font-size: 0.88rem; color: var(--muted); padding: 5px 0; \}\par
  .summary-line.total \{ font-weight: 700; color: var(--navy); font-size: 1rem; border-top: 1px solid var(--border); padding-top: 10px; margin-top: 4px; \}\par
  .btn-pay \{\par
    width: 100%;\par
    background: linear-gradient(135deg, var(--gold), var(--gold-light));\par
    color: var(--navy); font-weight: 700; font-size: 1rem;\par
    padding: 14px; border-radius: 8px; border: none; cursor: pointer;\par
    box-shadow: 0 4px 20px rgba(201,168,76,0.35);\par
    margin-top: 1.4rem; transition: transform .2s;\par
  \}\par
  .btn-pay:hover \{ transform: translateY(-2px); \}\par
\par
  /* ===== SUCCESS MODAL ===== */\par
  .modal-overlay \{\par
    display: none; position: fixed; inset: 0;\par
    background: rgba(10,22,40,0.7); z-index: 200;\par
