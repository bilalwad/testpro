    const tva = (price * 0.077).toFixed(2).replace('.', ',');\par
    const total = (price * 1.077).toFixed(2).replace('.', ',');\par
    document.getElementById('sum-tva').textContent = `$\{tva\} CHF`;\par
    document.getElementById('sum-total').textContent = `$\{total\} CHF`;\par
    showScreen('screen-payment');\par
  \}\par
\}\par
\par
function formatCard(el) \{\par
  let v = el.value.replace(/\\D/g, '').substring(0, 16);\par
  el.value = v.replace(/(.\{4\})/g, '$1 ').trim();\par
\}\par
\par
function processPayment() \{\par
  const name = document.getElementById('pay-name').value.trim();\par
  if (!name) \{ alert('Veuillez entrer votre nom complet.'); return; \}\par
  userName = name;\par
  document.getElementById('modal').classList.add('active');\par
\}\par
\par
function closeModalAndStartTest() \{\par
  document.getElementById('modal').classList.remove('active');\par
  initTest();\par
  showScreen('screen-test');\par
\}\par
\par
// ===== TEST =====\par
function initTest() \{\par
  currentQ = 0;\par
  answers = new Array(QUESTIONS.length).fill(null);\par
  timeLeft = 20 * 60;\par
  timeUsed = 0;\par
  if (timerInterval) clearInterval(timerInterval);\par
\par
  document.getElementById('test-title-main').textContent = currentTest.title;\par
  document.getElementById('side-test-name').textContent = currentTest.title;\par
\par
  buildDots();\par
  renderQuestion();\par
  startTimer();\par
\}\par
\par
function buildDots() \{\par
  const wrap = document.getElementById('q-dots');\par
  wrap.innerHTML = '';\par
  QUESTIONS.forEach((_, i) => \{\par
    const d = document.createElement('div');\par
    d.className = 'q-dot' + (i === 0 ? ' current' : '');\par
    d.textContent = i + 1;\par
    d.onclick = () => goToQ(i);\par
    wrap.appendChild(d);\par
  \});\par
\}\par
\par
function updateDots() \{\par
  const dots = document.querySelectorAll('.q-dot');\par
  dots.forEach((d, i) => \{\par
    d.className = 'q-dot';\par
    if (answers[i] !== null) d.classList.add('answered');\par
    if (i === currentQ) d.classList.add('current');\par
  \});\par
  const answered = answers.filter(a => a !== null).length;\par
  document.getElementById('progress-txt').textContent = `$\{answered\} / $\{QUESTIONS.length\}`;\par
  document.getElementById('progress-fill').style.width = `$\{(answered / QUESTIONS.length) * 100\}%`;\par
  document.getElementById('q-counter').textContent = `Question $\{currentQ + 1\} / $\{QUESTIONS.length\}`;\par
\}\par
\par
function renderQuestion() \{\par
  const q = QUESTIONS[currentQ];\par
  const area = document.getElementById('question-area');\par
  const letters = ['A','B','C','D'];\par
  area.innerHTML = `\par
    <div class="question-card">\par
      <div class="q-num">Question $\{currentQ + 1\} sur $\{QUESTIONS.length\}</div>\par
      <div class="q-text">$\{q.q\}</div>\par
      <div class="options">\par
        $\{q.options.map((opt, i) => `\par
          <div class="option $\{answers[currentQ] === i ? 'selected' : ''\}" onclick="selectOption($\{i\})">\par
            <div class="option-letter">$\{letters[i]\}</div>\par
            <span>$\{opt\}</span>\par
          </div>\par
        `).join('')\}\par
      </div>\par
    </div>`;\par
\par
  document.getElementById('btn-prev').style.visibility = currentQ === 0 ? 'hidden' : 'visible';\par
\par
  const isLast = currentQ === QUESTIONS.length - 1;\par
  const btn = document.getElementById('btn-next');\par
  btn.textContent = isLast ? 'Terminer l\\'examen \f2\u10003?\f0 ' : 'Suivant \f5\u8594?\f0 ';\par
  btn.className = isLast ? 'btn-submit' : 'btn-nav';\par
\par
  updateDots();\par
\}\par
\par
function selectOption(i) \{\par
  answers[currentQ] = i;\par
  renderQuestion();\par
\}\par
\par
function nextQ() \{\par
  if (currentQ === QUESTIONS.length - 1) \{\par
    finishTest();\par
  \} else \{\par
    currentQ++;\par
    renderQuestion();\par
  \}\par
\}\par
\par
function prevQ() \{ if (currentQ > 0) \{ currentQ--; renderQuestion(); \} \}\par
function goToQ(i) \{ currentQ = i; renderQuestion(); \}\par
\par
function startTimer() \{\par
  timerInterval = setInterval(() => \{\par
    timeLeft--;\par
    timeUsed++;\par
    const m = Math.floor(timeLeft / 60);\par
    const s = timeLeft % 60;\par
    const el = document.getElementById('timer');\par
    el.textContent = `$\{String(m).padStart(2,'0')\}:$\{String(s).padStart(2,'0')\}`;\par
    el.className = 'timer-val' + (timeLeft < 120 ? ' warning' : '');\par
    if (timeLeft <= 0) finishTest();\par
  \}, 1000);\par
\}\par
\par
function finishTest() \{\par
  clearInterval(timerInterval);\par
  const correct = answers.filter((a, i) => a === QUESTIONS[i].correct).length;\par
  const total = QUESTIONS.length;\par
  const pct = Math.round((correct / total) * 100);\par
  const passed = pct >= 60;\par
  const tm = Math.floor(timeUsed / 60);\par
  const ts = timeUsed % 60;\par
\par
  document.getElementById('res-pct').innerHTML = `$\{pct\}<span>%</span>`;\par
  document.getElementById('res-status').textContent = passed ? '\f2\u9989?\f1  \f0 Examen r\'e9ussi' : '\f2\u10060?\f1  \f0 Examen non valid\'e9';\par
  document.getElementById('res-msg').textContent = passed\par
    ? 'F\'e9licitations ! Vous avez atteint le seuil requis de 60%.'\par
    : 'Score insuffisant. Le seuil de r\'e9ussite est fix\'e9 \'e0 60%. Vous pouvez repasser l\\'examen.';\par
  document.getElementById('res-correct').textContent = correct;\par
  document.getElementById('res-wrong').textContent = total - correct;\par
  document.getElementById('res-time').textContent = `$\{String(tm).padStart(2,'0')\}:$\{String(ts).padStart(2,'0')\}`;\par
\par
  if (!passed) \{\par
    document.getElementById('cert-promo').innerHTML = `\par
      <div class="cert-icon">\f3\u-10179?\u-8998?\f0 </div>\par
      <div class="cert-text">\par
        <h3>R\'e9essayez pour obtenir votre certificat</h3>\par
        <p>Vous n'avez pas atteint le seuil de 60% requis. R\'e9visez les points abord\'e9s et tentez \'e0 nouveau votre chance !</p>\par
        <div class="cert-actions">\par
          <button class="btn-cert" onclick="startTest('$\{currentTest.title\}','$\{currentTest.category\}','$\{currentTest.icon\}',$\{currentTest.price\})">\f3\u-10179?\u-8956?\f1  \f0 Repasser l'examen</button>\par
          <button class="btn-outline" onclick="showScreen('screen-home')">Retour au catalogue</button>\par
        </div>\par
      </div>`;\par
  \}\par
\par
  // Review\par
  const reviewEl = document.getElementById('review-items');\par
  reviewEl.innerHTML = QUESTIONS.map((q, i) => \{\par
    const isCorrect = answers[i] === q.correct;\par
    const userAns = answers[i] !== null ? q.options[answers[i]] : 'Non r\'e9pondu';\par
    return `<div class="review-item">\par
      <div class="review-icon">$\{isCorrect ? '\f2\u9989?\f0 ' : '\f2\u10060?\f0 '\}</div>\par
      <div>\par
        <div class="review-q">$\{q.q\}</div>\par
        <div class="review-ans">Votre r\'e9ponse : <span class="$\{isCorrect ? 'correct-ans' : 'wrong-ans'\}">$\{userAns\}</span></div>\par
        $\{!isCorrect ? `<div class="review-ans">Bonne r\'e9ponse : <span class="correct-ans">$\{q.options[q.correct]\}</span></div>` : ''\}\par
      </div>\par
    </div>`;\par
  \}).join('');\par
\par
  showScreen('screen-results');\par
\}\par
\par
// ===== CERTIFICATE =====\par
function showCertificate() \{\par
  const pct = document.getElementById('res-pct').textContent.replace('%','').replace(/[^0-9]/g,'');\par
  const name = userName || 'Votre Nom';\par
  document.getElementById('cert-name').textContent = name;\par
  document.getElementById('cert-test-name').textContent = currentTest.title;\par
  document.getElementById('cert-score').textContent = pct + '%';\par
  document.getElementById('cert-id').innerHTML = `TP-2026-<span style="font-weight:700;">$\{Math.floor(10000 + Math.random()*90000)\}</span>`;\par
  const now = new Date();\par
  document.getElementById('cert-date').textContent = now.toLocaleDateString('fr-CH', \{ day: 'numeric', month: 'long', year: 'numeric' \});\par
  showScreen('screen-cert');\par
\}\par
\par
function printCert() \{\par
  window.print();\par
\}\par
\par
function shareCert() \{\par
  alert('Fonctionnalit\'e9 LinkedIn : votre certificat serait partag\'e9 sur votre profil avec la description et le score obtenu.');\par
\}\par
</script>\par
</body>\par
</html>\lang12\par
}
